        {
          "name": "用户登录",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response.code === 200 && response.data.token) {",
                  "    pm.environment.set(\"token\", response.data.token);",
                  "    console.log(\"Token saved:\", response.data.token);",
                  "}"
